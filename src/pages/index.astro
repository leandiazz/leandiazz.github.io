---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
---

<style>
  :root {
    --section-border: 30px;
    --section-padding: 50px;
    --items-gap: 30px;
  }

  .first-section {
    max-width: 1660px;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1.4fr;
    gap: var(--items-gap);
    & .group {
      background-color: var(--white);
      border-radius: var(--section-border);
      padding: var(--section-padding);
    }
    .about {
      h1 {
        font-size: 40px;
        margin: 0;
        line-height: 61px;
      }
      p {
        font-size: 18px;
        line-height: 35px;
      }
      .contact {
        padding-top: 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        & ul {
          list-style: none;
          padding-left: 0;
          display: flex;
          align-items: center;
          gap: 1rem;
        }
        & button {
          cursor: pointer;
          background-color: var(--black);
          color: var(--white);
          border: 0;
          font-size: 28px;
          padding: 10px 40px;
          border-radius: 25px;
        }
      }
    }
    & .controls {
      display: flex;
      flex-direction: column;
      gap: var(--items-gap);
      & .group {
        height: 50%;
      }
    }
    .clock {
      display: grid;
      place-items: center;
    }
    .studies {
      .items {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .study {
        h3 {
          font-size: 18px;
          margin: 0;
          & span {
            font-size: 12px;
            font-weight: normal;
          }
        }
        p {
          font-size: 15px;
          line-height: 28px;
        }
      }
    }
  }
  .second-section {
    margin-top: var(--items-gap);
    display: grid;
    grid-template-columns: 3fr 1.365fr;
    max-width: 1660px;
    margin-inline: auto;
    gap: var(--items-gap);
    & .group {
      background-color: var(--white);
      border-radius: var(--section-border);
      padding: var(--section-padding);
    }

    .carrousel-control {
      /* TODO make carrousel of projects ......... */
      width: 100%;
      height: 100px;
      background-color: rgb(196, 177, 177);
    }
    .work-case {
      display: flex;
      gap: 50px;
      img {
        width: 500px;
        border-radius: 10px;
      }
      .text {
        line-height: 28px;
      }
      .title {
        margin-top: 40px;
        display: flex;
        align-items: center;
        gap: 20px;
        height: 32px;
        h3 {
          font-size: 25px;
          margin: 0;
        }
        & ul {
          list-style: none;
          padding-left: 0;
          display: flex;
          align-items: center;
          gap: 15px;
          & a {
            display: grid;
            place-items: center;
          }
        }
      }
      .more-details {
        cursor: pointer;
        background-color: var(--black);
        color: var(--white);
        border: 0;
        font-size: 18px;
        border-radius: 20px;
        width: 175px;
        height: 40px;
      }
    }
  }
  .section-title {
    font-size: 40px;
    line-height: 40px;
    margin-block: 0 30px;
  }
</style>
